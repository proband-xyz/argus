# STAC v3 harness — non-secret defaults.
#
# Copy to `.env` for local use. The defaults below are intentionally
# weak ("dev_pw") and must NEVER be reused outside this prototype.
# All hosts bind to 127.0.0.1 only.

# ---------- Keycloak ----------
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=enterprise

# ---------- PostgreSQL ----------
POSTGRES_USER=stac
POSTGRES_PASSWORD=stac_dev_pw
POSTGRES_DB=enterprise
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------- Gitea ----------
# Bootstrap-only credentials; setup.sh will create this user.
GITEA_ADMIN_USER=stac-admin
GITEA_ADMIN_PASSWORD=stac_dev_pw
GITEA_ADMIN_EMAIL=stac-admin@example.com
GITEA_HOST=gitea
GITEA_PORT=3000

# ---------- MinIO ----------
MINIO_ROOT_USER=stac_minio
MINIO_ROOT_PASSWORD=stac_minio_dev_pw
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------- Mailpit ----------
SMTP_HOST=mailpit
SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ---------- OpenSearch ----------
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
