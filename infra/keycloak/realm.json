    },
    {
      "username": "dave.manager",
      "email": "dave.manager@example.com",
      "firstName": "Dave",
      "lastName": "Manager",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "dave_dev_pw", "temporary": false }
