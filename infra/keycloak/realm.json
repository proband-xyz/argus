    }
  ],
  "clientScopes": [
    {
      "name": "kc-admin-readonly",
      "description": "Marker scope: persona may read Keycloak admin API (view-users).",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "minio-exports-rw",
      "description": "Marker scope: persona may read/write the MinIO exports bucket.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "gitea-repo-read",
      "description": "Marker scope: persona may read public Gitea repos.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    }
  ],
  "clients": [
    {
      "clientId": "stac-agent",
      "name": "Argus victim agent",
      "description": "Used by the helpdesk-role agent under test.",
      "enabled": true,
      "publicClient": false,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": true,
      "secret": "stac-agent-dev-secret",
      "redirectUris": ["http://localhost/*"],
      "webOrigins": ["+"],
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "kc-admin-readonly",
        "minio-exports-rw",
        "gitea-repo-read"
      ],
      "protocolMappers": [
        {
          "name": "audience-minio",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "minio",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "audience-gitea",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "gitea",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "audience-account",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "account",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "stac-role-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "false",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "stac_role",
            "jsonType.label": "String",
            "usermodel.realmRoleMapping.rolePrefix": ""
          }
        },
        {
          "name": "stac-minio-policy-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "stac_minio_policy",
            "claim.name": "stac_minio_policy",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false",
            "aggregate.attrs": "false"
          }
        }
      ]
    }
  ]
}
