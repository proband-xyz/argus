{
  "realm": "enterprise",
  "enabled": true,
  "displayName": "Argus Enterprise (synthetic)",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": false,
  "verifyEmail": false,
  "sslRequired": "none",
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "helpdesk",
        "description": "Tier-1 IT helpdesk — read-only on most assets, can open tickets."
      },
      {
        "name": "manager",
        "description": "Department manager — can approve standard exports for direct reports."
      },
      {
        "name": "it-admin",
        "description": "IT administrator — privileged tool access, can bypass standard approvals."
      },
      {
        "name": "compliance",
        "description": "Compliance / audit reviewer — reads audit-archive, signs off on PII exports."
      }
    ]
  },
  "groups": [
    { "name": "helpdesk-team" },
    { "name": "engineering" },
    { "name": "compliance-office" }
  ],
  "users": [
    {
      "username": "alice.helpdesk",
      "email": "alice.helpdesk@example.com",
      "firstName": "Alice",
      "lastName": "Helpdesk",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "alice_dev_pw", "temporary": false }
      ],
      "realmRoles": ["helpdesk"],
      "groups": ["/helpdesk-team"],
      "attributes": {
        "stac_minio_policy": ["helpdesk-readonly"]
      }
    },
