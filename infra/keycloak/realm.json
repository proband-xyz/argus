    {
      "username": "erin.manager",
      "email": "erin.manager@example.com",
      "firstName": "Erin",
      "lastName": "Manager",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "erin_dev_pw", "temporary": false }
